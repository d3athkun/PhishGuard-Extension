{
  "manifest_version": 3,
  "name": "PhishGuard — Phishing Detector",
  "version": "1.0.0",
  "description": "Real-time phishing website detection powered by machine learning. Auto-scans every site you visit and lets you manually check any URL.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PhishGuard"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab",
    "tabs",
    "notifications",
    "storage"
  ],

  "host_permissions": [
    "http://localhost:5000/*",
    "https://phishguard-extension-9enx.onrender.com/*"
  ]
}
